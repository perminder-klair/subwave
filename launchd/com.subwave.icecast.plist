<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.subwave.icecast</string>
  <key>ProgramArguments</key>
  <array>
    <string>${ICECAST_BIN}</string>
    <string>-c</string>
    <string>${STATE_DIR}/icecast.xml</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${STATE_DIR}/logs/icecast.out</string>
  <key>StandardErrorPath</key>
  <string>${STATE_DIR}/logs/icecast.err</string>
</dict>
</plist>
