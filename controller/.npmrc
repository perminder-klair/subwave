# @openrouter/ai-sdk-provider still declares `peer ai@^6` and has no v7 build yet.
# Its model is provider-spec v2, which the ai v7 runtime accepts and upgrades
# (resolveLanguageModel -> asLanguageModelV4 handles v2/v3/v4), so the only thing
# stale is the declared peer RANGE, not actual compatibility. Relax peer checks
# until OpenRouter ships a v7-compatible release, then drop this file.
legacy-peer-deps=true
