{
  "expo": {
    "name": "SUB/WAVE",
    "slug": "subwave",
    "scheme": "subwave",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/b834b64c-f694-4f45-b3fa-0f2c0a4df5ba",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.getsubwave.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "SUB/WAVE uses the local network to find Google Cast speakers and TVs on your Wi-Fi so you can send the station to them.",
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.getsubwave.app",
      "adaptiveIcon": {
        "backgroundColor": "#100e0c",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "react-native-google-cast",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#100e0c"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "usesCleartextTraffic": true
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "./plugins/withGradleVersion",
        {
          "version": "8.14.3"
        }
      ],
      "./plugins/withAndroidUserCaTrust",
      "./plugins/withGradleMemory"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "featuredStation": {
        "url": "https://www.getsubwave.com",
        "name": "SUB/WAVE"
      },
      "directoryUrl": "https://www.getsubwave.com",
      "router": {},
      "eas": {
        "projectId": "b834b64c-f694-4f45-b3fa-0f2c0a4df5ba"
      }
    },
    "owner": "pinku1"
  }
}
