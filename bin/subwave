#!/usr/bin/env node
// Operator CLI entry. Registers the tsx loader so the TS source under
// cli/src/ transforms at import time — no build step. The launcher itself
// must stay JS, since the loader is only active for imports that happen
// *after* register() runs.

import { register } from 'tsx/esm/api';
import { resolve, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';

register();
const here = dirname(fileURLToPath(import.meta.url));
await import(resolve(here, '..', 'cli', 'src', 'cli.ts'));
